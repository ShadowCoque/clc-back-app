generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TipoPregunta {
  SI_NO
  DESCRIPCION
  NOMBRE_SOCIO
  ESCALA_1_10
}

enum RolUsuario {
  ADMIN
  GERENTE
  REPORTES
}

model Area {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique @db.VarChar(100)
  slug        String  @unique @db.VarChar(100)
  descripcion String? @db.Text
  activa      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preguntas     Pregunta[]
  colaboradores Colaborador[]
  encuestas     Encuesta[]
}

model Colaborador {
  id       Int    @id @default(autoincrement())
  nombre   String @db.VarChar(100)
  apellido String @db.VarChar(100)

  areaId Int
  area   Area @relation(fields: [areaId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encuestas Encuesta[]

  @@index([areaId])
  @@index([activo])
}

model Pregunta {
  id Int @id @default(autoincrement())

  areaId Int
  area   Area @relation(fields: [areaId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  texto       String       @db.Text
  tipo        TipoPregunta
  orden       Int
  obligatoria Boolean      @default(true)
  activa      Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  respuestas Respuesta[]

  @@unique([areaId, orden])
  @@index([areaId])
  @@index([activa])
}

model Encuesta {
  id Int @id @default(autoincrement())

  areaId Int
  area   Area @relation(fields: [areaId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  colaboradorId Int?
  colaborador   Colaborador? @relation(fields: [colaboradorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  nombreSocio String @db.VarChar(150)
  ipAddress   String @db.VarChar(45)

  fechaEnvio DateTime @default(now())
  fechaDia   DateTime @db.Date

  respuestas Respuesta[]

  @@index([areaId])
  @@index([colaboradorId])
  @@index([fechaEnvio])
  @@index([ipAddress])
  @@index([areaId, fechaEnvio])
  @@index([colaboradorId, fechaEnvio])
  @@index([fechaDia])
  @@index([areaId, fechaDia])
  @@index([colaboradorId, fechaDia])
  @@index([ipAddress, areaId, fechaDia])
}

model Respuesta {
  id Int @id @default(autoincrement())

  encuestaId Int
  encuesta   Encuesta @relation(fields: [encuestaId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  preguntaId Int
  pregunta   Pregunta @relation(fields: [preguntaId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  valorBooleano Boolean?
  valorTexto    String?  @db.Text
  valorNumero   Int?

  createdAt DateTime @default(now())

  @@unique([encuestaId, preguntaId])
  @@index([encuestaId])
  @@index([preguntaId])
}

model Usuario {
  id Int @id @default(autoincrement())

  email        String     @unique @db.VarChar(150)
  passwordHash String     @db.Text
  nombre       String     @db.VarChar(150)
  rol          RolUsuario

  activo Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([rol])
  @@index([activo])
}